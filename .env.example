# JAX Playground Environment Configuration
# Copy this file to .env and modify as needed

# JAX Configuration
# Enable 64-bit precision (for numerical stability)
JAX_ENABLE_X64=True

# Use CPU only (set to False to allow GPU/TPU)
JAX_PLATFORM_NAME=cpu

# Memory pre-allocation (useful for debugging)
# JAX_PLATFORMS=cpu
# XLA_FLAGS="--xla_force_host_platform_device_count=4"

# Python & Jupyter
PYTHONHASHSEED=42
JUPYTER_ENABLE_LAB_TREE_GATE=False

# Development
PYTEST_ADDOPTS=-v
